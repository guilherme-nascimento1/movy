generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum TenantPlan {
  STARTER
  BUSINESS
  PRO
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
  INSTRUCTOR
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum EnrollmentStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  FROZEN
}

enum PaymentMethod {
  PIX
  BOLETO
  CARD
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum LeadStage {
  NEW
  CONTACTED
  DEMO
  NEGOTIATION
  WON
  LOST
}

enum NotifChannel {
  WHATSAPP
  EMAIL
  PUSH
}

enum NotifStatus {
  PENDING
  SENT
  FAILED
}

// ─── TENANT ──────────────────────────────────────────────

model Tenant {
  id              String      @id @default(uuid())
  name            String
  slug            String      @unique
  plan            TenantPlan  @default(STARTER)
  settings        Json        @default("{}")
  active          Boolean     @default(true)
  trialEndsAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  // Dados da academia
  phone           String?
  email           String?
  cnpj            String?
  address         String?
  city            String?
  state           String?     // UF: "SP", "RJ"...
  zipCode         String?
  logoUrl         String?
  website         String?
  instagram       String?
  whatsappNumber  String?
  businessHours   String?     // ex: "Seg-Sex 06h–22h | Sáb 08h–14h"
  users        User[]
  students     Student[]
  academyPlans AcademyPlan[]
  classes      Class[]
  leads        Lead[]
  units        Unit[]
}

// ─── USER (colaboradores da academia) ────────────────────

model User {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  email        String
  passwordHash String
  role         UserRole @default(STAFF)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

// ─── STUDENT (alunos) ────────────────────────────────────

model Student {
  id            String         @id @default(uuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  name          String
  cpf           String?
  email         String?
  phone         String?
  photoUrl      String?
  birthdate     DateTime?
  status        StudentStatus  @default(ACTIVE)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  enrollments      Enrollment[]
  checkins         ClassCheckin[]
  workouts         Workout[]
  physicalEvals    PhysicalEval[]
  wodResults        WodResult[]
  personalRecords   PersonalRecord[]
  beltGraduations   BeltGraduation[]
  churnAlerts       ChurnAlert[]
  churnRiskScore    Int       @default(0)
  churnRiskUpdatedAt DateTime?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, name])
}

// ─── ACADEMY PLAN (planos da academia) ───────────────────

model AcademyPlan {
  id           String       @id @default(uuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  name         String
  price        Decimal      @db.Decimal(10, 2)
  durationDays Int
  description  String?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  enrollments  Enrollment[]

  @@index([tenantId])
}

// ─── ENROLLMENT (matrículas) ─────────────────────────────

model Enrollment {
  id        String           @id @default(uuid())
  tenantId  String
  studentId String
  student   Student          @relation(fields: [studentId], references: [id])
  planId    String
  plan      AcademyPlan      @relation(fields: [planId], references: [id])
  startDate DateTime
  endDate   DateTime
  status    EnrollmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  payments  Payment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, endDate])
  @@index([studentId])
}

// ─── PAYMENT (financeiro) ────────────────────────────────

model Payment {
  id           String        @id @default(uuid())
  tenantId     String
  enrollmentId String
  enrollment   Enrollment    @relation(fields: [enrollmentId], references: [id])
  amount       Decimal       @db.Decimal(10, 2)
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  dueDate      DateTime
  paidAt       DateTime?
  externalId   String?
  pixCode      String?
  boletoUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([externalId])
}

// ─── CLASS (aulas/turmas) ────────────────────────────────

model Class {
  id           String          @id @default(uuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  name         String
  instructorId String?
  weekday      Int
  startTime    String
  endTime      String
  capacity     Int
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  schedules    ClassSchedule[]

  @@index([tenantId])
}

model ClassSchedule {
  id        String         @id @default(uuid())
  classId   String
  class     Class          @relation(fields: [classId], references: [id])
  date      DateTime       @db.Date
  status    String         @default("SCHEDULED")
  createdAt DateTime       @default(now())
  checkins  ClassCheckin[]

  @@index([classId])
  @@index([date])
}

model ClassCheckin {
  id              String        @id @default(uuid())
  classScheduleId String
  schedule        ClassSchedule @relation(fields: [classScheduleId], references: [id])
  studentId       String
  student         Student       @relation(fields: [studentId], references: [id])
  checkedAt       DateTime      @default(now())

  @@unique([classScheduleId, studentId])
  @@index([studentId])
}

// ─── WORKOUT (treinos) ───────────────────────────────────

model Exercise {
  id          String        @id @default(uuid())
  tenantId    String
  name        String
  category    String?
  videoUrl    String?
  description String?
  createdAt   DateTime      @default(now())
  items           WorkoutItem[]
  personalRecords PersonalRecord[]

  @@index([tenantId])
  @@index([tenantId, name])
}

model Workout {
  id        String        @id @default(uuid())
  tenantId  String
  studentId String
  student   Student       @relation(fields: [studentId], references: [id])
  createdBy String
  name      String
  notes     String?
  createdAt DateTime      @default(now())
  items     WorkoutItem[]

  @@index([tenantId])
  @@index([studentId])
}

model WorkoutItem {
  id         String   @id @default(uuid())
  workoutId  String
  workout    Workout  @relation(fields: [workoutId], references: [id])
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  sets       Int
  reps       String
  restSecs   Int?
  notes      String?
  order      Int
}

// ─── LEAD (CRM) ──────────────────────────────────────────

model Lead {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  phone     String?
  email     String?
  source    String?
  stage     LeadStage @default(NEW)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, stage])
}

// ─── PHYSICAL EVAL (avaliação física) ───────────────────

model PhysicalEval {
  id          String    @id @default(uuid())
  tenantId    String
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  evaluatedAt DateTime  @default(now())
  nextEvalAt  DateTime?
  evaluatedBy String?
  active      Boolean   @default(true)

  // Anamnese
  objectives    String?
  healthHistory Json    @default("{}")
  parqAnswers   Json    @default("{}")

  // Protocolo de dobras
  protocol String? // POLLOCK_3, POLLOCK_7, JACKSON_POLLOCK, DURNIN_WOMERSLEY

  // Composição corporal
  weight   Decimal? @db.Decimal(5, 2) // kg
  height   Decimal? @db.Decimal(5, 2) // cm
  bmi      Decimal? @db.Decimal(4, 2) // calculado automaticamente
  bodyFat  Decimal? @db.Decimal(4, 2) // %
  leanMass Decimal? @db.Decimal(5, 2) // kg

  // Circunferências (cm)
  waist   Decimal? @db.Decimal(5, 1)
  hip     Decimal? @db.Decimal(5, 1)
  chest   Decimal? @db.Decimal(5, 1)
  abdomen Decimal? @db.Decimal(5, 1)
  thigh   Decimal? @db.Decimal(5, 1)
  arm     Decimal? @db.Decimal(5, 1)
  calf    Decimal? @db.Decimal(5, 1)

  // Dobras cutâneas (mm)
  skinfoldChest       Decimal? @db.Decimal(4, 1)
  skinfoldAbdomen     Decimal? @db.Decimal(4, 1)
  skinfoldThigh       Decimal? @db.Decimal(4, 1)
  skinfoldTricep      Decimal? @db.Decimal(4, 1)
  skinfoldSubscapular Decimal? @db.Decimal(4, 1)
  skinfoldSuprailiac  Decimal? @db.Decimal(4, 1)
  skinfoldAxillary    Decimal? @db.Decimal(4, 1)

  // Sinais vitais
  bloodPressure String? // ex: "120/80"
  restingHR     Int? // bpm

  notes  String?
  photos Json    @default("[]")

  @@index([tenantId])
  @@index([studentId])
  @@index([studentId, evaluatedAt])
}

// ─── NOTIFICATION LOG ────────────────────────────────────

model NotificationLog {
  id        String       @id @default(uuid())
  tenantId  String
  type      String
  channel   NotifChannel
  status    NotifStatus  @default(PENDING)
  payload   Json
  sentAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([tenantId])
  @@index([tenantId, status])
}

// ─── CROSSFIT ────────────────────────────────────────────

model Wod {
  id          String      @id @default(uuid())
  tenantId    String
  date        DateTime    @db.Date
  title       String
  description String
  wodType     String // FOR_TIME, AMRAP, EMOM, TABATA, STRENGTH, CUSTOM
  timeCapSecs Int?
  rounds      Int?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  results     WodResult[]

  @@unique([tenantId, date])
  @@index([tenantId])
  @@index([tenantId, date])
}

model WodResult {
  id        String   @id @default(uuid())
  tenantId  String
  wodId     String
  wod       Wod      @relation(fields: [wodId], references: [id])
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  score     String // "12:34", "150 reps", "75 kg"
  scoreType String // TIME, REPS, WEIGHT, ROUNDS
  rx        Boolean  @default(false) // Rx ou Scaled
  notes     String?
  completedAt DateTime @default(now())

  @@unique([wodId, studentId])
  @@index([tenantId])
  @@index([studentId])
}

model PersonalRecord {
  id         String   @id @default(uuid())
  tenantId   String
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  value      Decimal  @db.Decimal(8, 2)
  unit       String   // kg, reps, seconds, meters
  notes      String?
  achievedAt DateTime @default(now())

  @@index([tenantId])
  @@index([studentId, exerciseId])
}

// ─── ARTES MARCIAIS ──────────────────────────────────────

enum BeltColor {
  WHITE
  YELLOW
  ORANGE
  GREEN
  BLUE
  PURPLE
  BROWN
  BLACK
  RED_BLACK
  RED_WHITE
  RED
}

model BeltGraduation {
  id         String    @id @default(uuid())
  tenantId   String
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id])
  belt       BeltColor
  stripes    Int       @default(0) // 0-4 graus/listras
  modality   String    // Jiu-Jitsu, Judô, Karatê, Muay Thai...
  graduatedAt DateTime @default(now())
  graduatedBy String?  // userId do professor
  notes      String?

  @@index([tenantId])
  @@index([studentId])
}

// ─── UNIT (multi-unidade) ────────────────────────────────

model Unit {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  address   String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ─── TEAM MEMBER (gestão de equipe) ─────────────────────

model TeamMember {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  name      String
  email     String
  role      UserRole
  specialty String?  // Ex: "Musculação", "CrossFit", "Pilates"
  bio       String?
  photoUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  goals     TeamGoal[]

  @@unique([tenantId, userId])
  @@index([tenantId])
}

model TeamGoal {
  id           String     @id @default(uuid())
  tenantId     String
  memberId     String
  member       TeamMember @relation(fields: [memberId], references: [id])
  title        String
  targetValue  Decimal    @db.Decimal(10, 2)
  currentValue Decimal    @db.Decimal(10, 2) @default(0)
  unit         String     // "alunos", "R$", "aulas"
  dueDate      DateTime
  achieved     Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@index([tenantId])
  @@index([memberId])
}

// ─── MOVY AI ─────────────────────────────────────────────

model ChurnAlert {
  id        String   @id @default(uuid())
  tenantId  String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  score     Int
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([studentId])
}

model AiUsageLog {
  id         String   @id @default(uuid())
  tenantId   String
  endpoint   String
  tokensUsed Int
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
}
